// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 (학생/교사/관리자)
model User {
  id        String   @id @default(cuid())
  studentId String   @unique  // 학번 또는 사번
  name      String
  password  String
  role      Role     @default(STUDENT)
  grade     Int?     // 학년 (학생만)
  classNum  Int?     // 반 (학생만)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("users")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// 급식 메뉴 (날짜 + 조식/중식/석식)
model Meal {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  mealType  MealType
  menu      String[] // 메뉴 항목들 (배열)
  calories  Int?     // 칼로리
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@unique([date, mealType])
  @@map("meals")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

// 급식 신청
model Subscription {
  id        String   @id @default(cuid())
  userId    String
  mealId    String
  status    SubStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  meal Meal @relation(fields: [mealId], references: [id])

  @@unique([userId, mealId])
  @@map("subscriptions")
}

enum SubStatus {
  ACTIVE
  CANCELLED
}
